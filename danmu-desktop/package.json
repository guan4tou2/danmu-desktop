{
  "name": "danmu-desktop",
  "version": "5.4.0",
  "description": "Danmu overlay controller for live streaming",
  "main": "dist/main.bundle.js",
  "scripts": {
    "start": "npm run build:webpack && electron .",
    "pack": "npm run build:webpack && electron-builder --dir",
    "pack-dist": "npm run build:webpack && electron-builder",
    "sync:tokens": "node -e \"require('fs').copyFileSync('../shared/tokens.css','tokens.css')\"",
    "build:webpack": "npm run sync:tokens && webpack",
    "build:i18n": "node scripts/build-i18n.js",
    "build": "npm run build:i18n && npm run build:webpack",
    "test": "jest --testPathPatterns=tests/",
    "test:e2e": "npx playwright test"
  },
  "repository": "https://github.com/guan4tou2/danmu-desktop",
  "keywords": [
    "Electron",
    "quick",
    "start"
  ],
  "author": "guan4tou2 <mole30608@gmail.com>",
  "license": "CC0-1.0",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "babel-loader": "^10.1.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4.3.2",
    "terser-webpack-plugin": "^5.6.1",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "^../shared/utils$": "<rootDir>/shared/utils.js"
    }
  },
  "build": {
    "appId": "com.danmufire.desktop",
    "productName": "Danmu Desktop",
    "artifactName": "Danmu-Desktop-${version}-${os}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "guan4tou2",
      "repo": "danmu-desktop"
    },
    "directories": {
      "output": "pack"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "child.html",
      "child.css",
      "about.html",
      "about.css",
      "about-renderer.js",
      "overlay-idle.js",
      "tailwind.css",
      "styles.css",
      "tokens.css",
      "hud.css",
      "i18n.js",
      "client-nav.js",
      "assets/**/*",
      "package.json",
      "!main.js",
      "!renderer.js",
      "!preload.js",
      "!webpack.config.js",
      "!.babelrc",
      "!.vscode",
      "!.github"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.png",
      "compression": "maximum"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "compression": "maximum"
    },
    "deb": {
      "compression": "xz"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.4",
    "qrcode": "^1.5.4"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "@xmldom/xmldom": "^0.8.12",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "fast-uri": "^3.1.4",
    "ip-address": "^10.1.1",
    "tmp": "^0.2.6",
    "form-data": "^4.0.6",
    "undici": "^7.28.0",
    "ws": "^8.21.0",
    "js-yaml": "^3.15.0 || ^4.2.0"
  }
}
