{
  "name": "danmu-desktop",
  "version": "3.2.0",
  "description": "A danmu desktop",
  "main": "dist/main.bundle.js",
  "scripts": {
    "start": "npm run build:webpack && electron .",
    "pack": "npm run build:webpack && electron-builder --dir",
    "pack-dist": "npm run build:webpack && electron-builder",
    "build:webpack": "webpack",
    "test": "jest --testPathPatterns=tests/"
  },
  "repository": "https://github.com/guan4tou2/danmu-desktop",
  "keywords": [
    "Electron",
    "quick",
    "start"
  ],
  "author": "guan4tou2 <mole30608@gmail.com>",
  "license": "CC0-1.0",
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@jest/globals": "^30.2.0",
    "babel-loader": "^10.0.0",
    "electron": "^36.8.1",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "serialize-javascript": "7.0.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "^../shared/utils$": "<rootDir>/shared/utils.js"
    }
  },
  "build": {
    "appId": "com.example.app",
    "productName": "danmu manager",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "pack"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "child.html",
      "child.css",
      "tailwind.css",
      "styles.css",
      "i18n.js",
      "assets/**/*",
      "package.json",
      "!main.js",
      "!renderer.js",
      "!preload.js",
      "!webpack.config.js",
      "!.babelrc",
      "!.vscode",
      "!.github"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "compression": "maximum"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "compression": "maximum"
    },
    "deb": {
      "compression": "xz"
    }
  }
}
