name: wave
label: 波浪
description: 文字傾斜波浪

params:
  duration:
    label: 速度 (秒)
    type: float
    default: 0.5
    min: 0.1
    max: 3.0
    step: 0.1
  angle:
    label: 角度 (deg)
    type: int
    default: 8
    min: 1
    max: 30
    step: 1

keyframes: |
  @keyframes dme-wave {
    0%, 100% { transform: skewX(0deg); }
    50% { transform: skewX({angle}deg); }
  }

animation: "dme-wave {duration}s ease-in-out infinite"
