name: rainbow
label: 彩虹
description: 文字循環變色（彩虹效果）

params:
  duration:
    label: 週期 (秒)
    type: float
    default: 2.0
    min: 0.5
    max: 10.0
    step: 0.5

keyframes: |
  @keyframes dme-rainbow {
    0%   { color: #ff0000; }
    16%  { color: #ff8800; }
    33%  { color: #ffee00; }
    50%  { color: #00cc44; }
    66%  { color: #0088ff; }
    83%  { color: #8844ff; }
    100% { color: #ff0000; }
  }

animation: dme-rainbow {duration}s linear infinite
composition: replace
