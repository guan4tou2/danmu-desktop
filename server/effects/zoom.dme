name: zoom
label: 縮放
description: 文字脈衝縮放

params:
  duration:
    label: 速度 (秒)
    type: float
    default: 0.8
    min: 0.2
    max: 3.0
    step: 0.1
  scale:
    label: 最大倍率
    type: float
    default: 1.3
    min: 1.05
    max: 2.0
    step: 0.05

keyframes: |
  @keyframes dme-zoom {
    0%, 100% { transform: scale(1); }
    50% { transform: scale({scale}); }
  }

animation: "dme-zoom {duration}s ease-in-out infinite"
