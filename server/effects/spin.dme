name: spin
label: 旋轉
description: 文字連續旋轉

params:
  duration:
    label: 速度 (秒)
    type: float
    default: 1.5
    min: 0.1
    max: 10.0
    step: 0.1
  direction:
    label: 方向
    type: select
    default: normal
    options:
      - value: normal
        label: 順時針
      - value: reverse
        label: 逆時針

keyframes: |
  @keyframes dme-spin {
    to { transform: rotate(360deg); }
  }

animation: "dme-spin {duration}s linear infinite {direction}"
